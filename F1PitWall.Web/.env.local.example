# CDN base URL for cached OpenF1 JSON files.
# Set this to your CloudFront distribution URL (no trailing slash).
# When set, session-keyed API calls are served from:
#   {VITE_OF1_CDN_BASE}/{session_key}/{endpoint}.json
# and fall back to the live OpenF1 API on cache miss.
#
# Leave empty (or remove this line) to always use the live API.
VITE_OF1_CDN_BASE=https://your-distribution.cloudfront.net
